# ─────────────────────────────────────────────────────────────────────────────
#  NutriAgent Bob — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# IBM Cloud API Key (required for Watsonx.ai)
# Generate at: https://cloud.ibm.com/iam/apikeys  → "Create an IBM Cloud API key"
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM Watsonx.ai Project ID (required)
# Find at: https://dataplatform.cloud.ibm.com/projects → your project → Manage tab
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM Watsonx.ai Service URL — must match the region your WML instance is in
# Options: https://us-south.ml.cloud.ibm.com
#          https://au-syd.ml.cloud.ibm.com
#          https://eu-de.ml.cloud.ibm.com
#          https://eu-gb.ml.cloud.ibm.com
#          https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Model ID — must be supported by your WML instance plan
# Run: python -c "from ibm_watsonx_ai import Credentials; from ibm_watsonx_ai.foundation_models import get_model_specs; ..."
# Available in au-syd Lite plan (confirmed):
#   meta-llama/llama-3-3-70b-instruct  (best for chat/nutrition, recommended)
#   meta-llama/llama-3-1-8b            (faster, smaller)
#   ibm/granite-8b-code-instruct
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# Flask settings
FLASK_SECRET_KEY=change_this_to_a_random_secret_string_at_least_32_chars
FLASK_DEBUG=false
PORT=5000
